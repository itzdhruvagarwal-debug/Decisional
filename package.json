{
  "name": "decisional",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build && node scripts/prepare-standalone.mjs",
    "postinstall": "prisma generate",
    "start": "node .next/standalone/server.js",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --pretty false",
    "validate": "npm run lint && npm run typecheck && npx prisma validate",
    "deploy:check": "npm run validate && npm run build",
    "seed": "npx tsx scripts/seed-test-accounts.ts"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1047.0",
    "@aws-sdk/s3-request-presigner": "^3.1047.0",
    "@prisma/client": "^6.19.3",
    "@sentry/nextjs": "^10.59.0",
    "bcryptjs": "^3.0.3",
    "compromise": "^14.14.5",
    "date-fns": "^4.1.0",
    "disposable-email-domains": "^1.0.62",
    "framer-motion": "^12.34.0",
    "ioredis": "^5.9.2",
    "isomorphic-dompurify": "^3.13.0",
    "next": "^16.2.6",
    "next-auth": "5.0.0-beta.30",
    "otplib": "^13.3.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "recharts": "^3.7.0",
    "server-only": "^0.0.1",
    "swr": "^2.4.2",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.14",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "^8.5.14"
  }
}
