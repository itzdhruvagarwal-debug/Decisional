# ==================== APP ====================
NODE_ENV="production"
PORT=3000
NEXTAUTH_URL="https://your-domain.com"
NEXT_PUBLIC_APP_URL="https://your-domain.com"
APP_BASE_URL="https://your-domain.com"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ==================== DATABASE - SUPABASE POSTGRES ====================
# Use the Supabase direct URL for migrations/admin tooling.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
# Use Supabase transaction pooler for Vercel runtime traffic. Required on Vercel unless using Prisma Accelerate.
PGBOUNCER_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true&connection_limit=1"
# Optional alternative to PGBOUNCER_URL.
PRISMA_ACCELERATE_URL=""

# ==================== REDIS - UPSTASH ====================
# Use the TLS rediss:// URL from Upstash.
REDIS_URL="rediss://default:YOUR_UPSTASH_PASSWORD@YOUR_UPSTASH_HOST.upstash.io:6379"
# Edge-compatible Upstash REST credentials (required for middleware Edge IP blacklist verification)
UPSTASH_REDIS_REST_URL="https://YOUR_UPSTASH_HOST.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR_UPSTASH_REST_TOKEN"

# ==================== AUTH PROVIDERS ====================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ==================== RAZORPAY (Payments) ====================
RAZORPAY_KEY_ID="rzp_live_xxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"
RAZORPAY_ACCOUNT_NUMBER="your_razorpay_account_number"

# ==================== CRON ====================
CRON_SECRET="generate-with: openssl rand -hex 32"

# ==================== CONTRACT / SIGNATURE ====================
CONTRACT_SIGNING_SECRET="generate-with: openssl rand -hex 32"
SIGNING_SECRET="generate-with: openssl rand -hex 32"

# ==================== SMS - MSG91 ====================
MSG91_AUTH_KEY=""
MSG91_SENDER_ID="DCSNL"
MSG91_TEMPLATE_ID=""

# ==================== WHATSAPP OTP ====================
# OTP_PRIMARY_CHANNEL="whatsapp" sends WhatsApp first, then SMS fallback.
OTP_PRIMARY_CHANNEL="whatsapp"
OTP_SMS_FALLBACK="true"
# Provider can be "auto", "twilio", or "meta".
WHATSAPP_PROVIDER="auto"
# Twilio WhatsApp Sandbox or approved sender, e.g. whatsapp:+14155238886
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM=""
# Meta WhatsApp Cloud API template fallback.
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_OTP_TEMPLATE_NAME=""
WHATSAPP_TEMPLATE_LANGUAGE="en_US"

# ==================== EMAIL - Resend ====================
RESEND_API_KEY=""
FROM_EMAIL="noreply@your-domain.com"
REPLY_TO_EMAIL="support@your-domain.com"

# ==================== KYC VERIFICATION ====================
# Provider: 'manual' | 'surepass' | 'digilocker'
KYC_PROVIDER="manual"
KYC_API_KEY=""

# ==================== CLOUD STORAGE - CLOUDFLARE R2 ====================
STORAGE_PROVIDER="r2"
S3_BUCKET="decisional-prod"
S3_REGION="auto"
S3_ACCESS_KEY="your_r2_access_key_id"
S3_SECRET_KEY="your_r2_secret_access_key"
S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
# Use your R2 custom public domain when possible, e.g. https://cdn.your-domain.com
STORAGE_PUBLIC_URL="https://cdn.your-domain.com"

# ==================== INSTAGRAM API ====================
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# ==================== YOUTUBE API ====================
YOUTUBE_API_KEY=

# ==================== DIGILOCKER API ====================
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=""

# ==================== APP CONFIG ====================
LOG_LEVEL="info"
HEALTHCHECK_SECRET="generate-with: openssl rand -hex 32"
PROMETHEUS_AUTH_TOKEN="generate-with: openssl rand -hex 32"

# ==================== MONITORING - SENTRY / PROMETHEUS ====================
SENTRY_DSN="https://<public-key>@o<org-id>.ingest.sentry.io/<project-id>"
NEXT_PUBLIC_SENTRY_DSN="https://<public-key>@o<org-id>.ingest.sentry.io/<project-id>"
SENTRY_ENVIRONMENT="production"
NEXT_PUBLIC_SENTRY_ENVIRONMENT="production"
SENTRY_RELEASE=""
NEXT_PUBLIC_SENTRY_RELEASE=""
# Only set in CI/Vercel build env if you want source map upload.
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05
NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0

PLATFORM_FEE_PERCENTAGE=10
GATEWAY_FEE_PERCENTAGE=2
MIN_WITHDRAWAL_AMOUNT=50000
MAX_WALLET_BALANCE=1000000000
ADMIN_EMAILS="admin@your-domain.com"

# ==================== ENCRYPTION ====================
# AES-256-GCM key map format: v1:<64-hex>,v2:<64-hex>
ENCRYPTION_KEYS="v1:YOUR_64_HEX_KEY"
# Backward compatibility (optional)
ENCRYPTION_KEY=""
HMAC_KEY="YOUR_64_HEX_HMAC_KEY"
